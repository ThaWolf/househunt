# Prefer root `.env.example` as source of truth; this file mirrors API-needed keys.
DATABASE_URL=postgresql+asyncpg://househunt:househunt@localhost:5432/househunt
JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
PORT=8000
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
ADAPTER_ZONAPROP_ENABLED=true
ADAPTER_ARGENPROP_ENABLED=true
ADAPTER_MERCADOLIBRE_ENABLED=true
ADAPTER_REMAX_ENABLED=true
ADAPTER_CENTURY21_ENABLED=true
ADAPTER_USE_FIXTURES=false
ADAPTER_TIMEOUT_SECONDS=45
FEATURE_GOOGLE_CALENDAR=false
FEATURE_POI=false
FEATURE_IMAGE_PROXY=true
# Prefer live ZonaProp + Mercado Libre (Playwright). Empty honest results > fake density.
# Set ADAPTER_USE_FIXTURES=true only for offline CI with curated fixtures (sample_listings.json is empty by default).
# RAILWAY_PUBLIC_URL=   # deferred until railway domain
