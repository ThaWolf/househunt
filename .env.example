# Copy to `.env` (repo root) and/or `services/api/.env`.
# Keys only — fill locally. Never commit real secrets.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://househunt:househunt@localhost:5432/househunt
# DATABASE_URL_RAILWAY_PRIVATE=   # optional in-network URL on Railway

# --- Auth (JWT) ---
JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# --- Google OAuth ---
# Local: redirect → http://localhost:8000/api/auth/google/callback
# Prod: use https://<your-domain>/api/auth/google/callback after domain exists
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- App / CORS ---
PORT=8000
# Dev: Vite origin. Prod Opción A (same origin): leave empty or omit.
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# --- Adapters ---
ADAPTER_ZONAPROP_ENABLED=true
ADAPTER_ARGENPROP_ENABLED=true
ADAPTER_MERCADOLIBRE_ENABLED=true
ADAPTER_REMAX_ENABLED=true
ADAPTER_CENTURY21_ENABLED=true
ADAPTER_USE_FIXTURES=true
ADAPTER_TIMEOUT_SECONDS=12

# --- Feature flags ---
FEATURE_GOOGLE_CALENDAR=false
FEATURE_POI=false
FEATURE_IMAGE_PROXY=true

# --- Railway (deferred until `railway domain`) ---
# RAILWAY_PUBLIC_URL=             # set after public domain; used for OAuth prod redirects
# See docs/deploy-railway.md
